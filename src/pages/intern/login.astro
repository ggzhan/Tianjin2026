---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { href } from '../../lib/paths';

const nextParam = Astro.url.searchParams.get('next') || '';
---

<BaseLayout title="Camp-Login" description="Passwortgeschützter Camp-Bereich für Teilnehmer:innen und Eltern." mode="intern" showLogout={false}>
  <div class="wrap">
    <div class="login-panel">
      <p class="eyebrow">Intern</p>
      <h1 style="font-size: clamp(1.5rem, 5vw, 1.85rem)">Camp-Bereich</h1>
      <p style="color: var(--muted); margin-top: 0">Gemeinsames Passwort für Spieler:innen und Eltern.</p>
      <p class="login-error" id="login-error" role="alert" hidden>
        Passwort stimmt nicht. Noch einmal versuchen — oder beim Coach nachfragen.
      </p>
      <form id="camp-login-form" novalidate>
        <input type="hidden" name="next" id="login-next" value={nextParam} />
        <label for="password">Passwort</label>
        <div class="password-field">
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            required
            autofocus
            aria-describedby="login-error"
            minlength="1"
          />
          <button type="button" class="password-toggle" id="password-toggle" aria-pressed="false" aria-controls="password">
            Zeigen
          </button>
        </div>
        <button class="btn btn-primary" type="submit" style="width: 100%" id="login-submit">Eintreten</button>
      </form>
    </div>
  </div>
</BaseLayout>

<script>
  import { tryUnlock, isUnlocked } from '../../lib/camp-auth';
  import { href } from '../../lib/paths';

  const internHome = href('/intern');
  const form = document.getElementById('camp-login-form') as HTMLFormElement | null;
  const errorEl = document.getElementById('login-error');
  const nextInput = document.getElementById('login-next') as HTMLInputElement | null;
  const passwordInput = document.getElementById('password') as HTMLInputElement | null;
  const toggle = document.getElementById('password-toggle') as HTMLButtonElement | null;
  const submitBtn = document.getElementById('login-submit') as HTMLButtonElement | null;

  function safeNext(raw: string) {
    if (!raw) return internHome;
    try {
      const url = new URL(raw, window.location.origin);
      if (!url.pathname.includes('/intern')) return internHome;
      if (url.pathname.includes('/intern/login')) return internHome;
      return url.pathname + url.search;
    } catch {
      return internHome;
    }
  }

  if (isUnlocked()) {
    window.location.replace(safeNext(nextInput?.value || ''));
  }

  toggle?.addEventListener('click', () => {
    if (!passwordInput || !toggle) return;
    const show = passwordInput.type === 'password';
    passwordInput.type = show ? 'text' : 'password';
    toggle.textContent = show ? 'Verbergen' : 'Zeigen';
    toggle.setAttribute('aria-pressed', show ? 'true' : 'false');
    passwordInput.focus();
  });

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!form || !passwordInput) return;

    const password = passwordInput.value.trim();
    if (!password) {
      if (errorEl) {
        errorEl.hidden = false;
        errorEl.textContent = 'Bitte Passwort eingeben.';
      }
      passwordInput.focus();
      return;
    }

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = 'Prüfen…';
    }

    const ok = await tryUnlock(password);
    if (!ok) {
      if (errorEl) {
        errorEl.hidden = false;
        errorEl.textContent = 'Passwort stimmt nicht. Noch einmal versuchen — oder beim Coach nachfragen.';
      }
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Eintreten';
      }
      passwordInput.select();
      passwordInput.focus();
      return;
    }

    window.location.replace(safeNext(String(new FormData(form).get('next') ?? '')));
  });
</script>
