---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { href } from '../../lib/paths';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Tagebuch" description="Lager-Tagebuch der Teilnehmer:innen — Updates alle 1–2 Tage aus Tianjin.">
  <section class="section">
    <div class="wrap diary">
      <p class="eyebrow">Öffentlich</p>
      <h1>Willkommen zu unserem Chinareise-Blog!</h1>
      <p class="lead">
        Das Lager-Tagebuch der Teilnehmer:innen. Alle ein bis zwei Tage ein neuer Eintrag — mit Text, Fotos und bald auch Videos.
      </p>

      <ol class="diary-feed">
        {
          posts.map((post) => (
            <li class="diary-entry">
              <a class="diary-entry__link" href={href(`/blog/${post.id}`)}>
                <time class="diary-entry__date" datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('de-CH', {
                    weekday: 'short',
                    day: 'numeric',
                    month: 'long',
                  })}
                </time>
                {
                  post.data.cover && (
                    <div class="diary-entry__media">
                      <img
                        src={post.data.cover.startsWith('http') ? post.data.cover : href(post.data.cover)}
                        alt={post.data.coverAlt || ''}
                        width="1200"
                        height="675"
                        loading="lazy"
                      />
                    </div>
                  )
                }
                <div class="diary-entry__body">
                  <h2>{post.data.title}</h2>
                  <p>{post.data.description}</p>
                  <span class="diary-entry__by">{post.data.author}</span>
                </div>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .diary {
    width: min(100% - 2rem, 42rem);
  }

  .diary-feed {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    gap: 2.5rem;
  }

  .diary-entry__link {
    display: grid;
    gap: 0.85rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.35s var(--ease-out);
  }

  .diary-entry__link:hover {
    transform: translateY(-3px);
  }

  .diary-entry__date {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--accent);
    letter-spacing: 0.02em;
  }

  .diary-entry__media {
    overflow: hidden;
    border-radius: 0.65rem;
    aspect-ratio: 16 / 9;
    background: var(--surface);
  }

  .diary-entry__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .diary-entry__body h2 {
    font-size: clamp(1.35rem, 3vw, 1.7rem);
    margin: 0 0 0.35rem;
  }

  .diary-entry__body p {
    margin: 0;
    color: var(--muted);
  }

  .diary-entry__by {
    display: inline-block;
    margin-top: 0.55rem;
    font-size: 0.88rem;
    color: var(--muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .diary-entry__link:hover {
      transform: none;
    }
  }
</style>
