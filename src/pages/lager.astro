---
import BaseLayout from '../layouts/BaseLayout.astro';
import { href } from '../lib/paths';
---

<BaseLayout title="Das Lager" description="Rahmen, Stadt und Trainingshintergrund für OTTV Tianjin 2026.">
  <section class="section">
    <div class="wrap narrow prose">
      <p class="eyebrow">Öffentlich</p>
      <h1>OTTV in Tianjin</h1>
      <p class="lead">Zwei Wochen China, Tischtennis und Team — mit Blick auf Stadt, Trainer und Halle.</p>
    </div>
  </section>

  <section class="section section--surface">
    <div class="wrap section-grid split">
      <div>
        <img
          src="https://images.unsplash.com/photo-1768396748025-b08ede3d4ea4?auto=format&fit=crop&w=1400&q=80"
          alt="Tianjin Skyline bei klarem Himmel"
          width="1400"
          height="900"
          loading="lazy"
          style="border-radius: 0.75rem; width: 100%; aspect-ratio: 4/3; object-fit: cover;"
        />
      </div>
      <div class="prose">
        <p class="eyebrow">Die Stadt</p>
        <h2>Tianjin</h2>
        <p>
          Tianjin ist eine bedeutende Hafenstadt im Nordosten Chinas und eine der vier regierungsunmittelbaren Städte.
          Ab Mitte des 19. Jahrhunderts wuchs sie zum Handelszentrum — geprägt durch ausländische Konzessionen nach den Opiumkriegen.
          Diese Geschichte zeigt sich bis heute in der europäischen Architektur der Innenstadt.
        </p>
        <p>
          Heute ist Tianjin Wirtschafts- und Industriezentrum sowie der wichtigste Seehafen für das nahe Peking.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap narrow prose">
      <p class="eyebrow">Tischtennis</p>
      <h2>Ma Wenge</h2>
      <p>
        Tianjin ist keine klassische Tischtennis-Metropole — und hat trotzdem Stars hervorgebracht: Hao Shuai, Li Fen und
        <strong>Ma Wenge</strong>, Olympia-Bronze 1992 (erste olympische Einzelmedaille der chinesischen Herren), zweimaliger World-Cup-Sieger
        und über ein Jahrzehnt Bundesliga-Legende in Deutschland.
      </p>
      <p>
        2009 kehrte er nach China zurück und wurde Cheftrainer der Herren von Tianjin. 2018 gründete er den
        «Ma Wenge Tischtennis-Club», um Nachwuchs an der Basis zu fördern.
      </p>
      <p class="callout" style="margin-top: 1.5rem">
        Im Lager trainieren wir in seiner Halle: zentral, Profi-Boden, 20 Tische — und das Hotel zehn Minuten zu Fuss.
        Adressen und Tagesplan stehen im <a href={href('/intern')}>Camp-Bereich</a>.
      </p>
    </div>
  </section>
</BaseLayout>
