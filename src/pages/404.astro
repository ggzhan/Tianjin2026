---
import BaseLayout from '../layouts/BaseLayout.astro';
import { href } from '../lib/paths';
---

<BaseLayout title="Seite nicht gefunden">
  <section class="wrap narrow miss">
    <p class="eyebrow">404</p>
    <h1>Seite nicht gefunden</h1>
    <p>Zurück zur <a href={href('/')}>Startseite</a> oder zum <a href={href('/blog')}>Tagebuch</a>.</p>
  </section>
</BaseLayout>

<style>
  .miss {
    padding-block: clamp(4rem, 12vw, 8rem);
  }
</style>
