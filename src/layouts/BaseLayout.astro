---
import '../styles/global.css';
import CampAuth from '../components/CampAuth.astro';
import { href, stripBase } from '../lib/paths';

interface Props {
  title: string;
  description?: string;
  mode?: 'public' | 'intern';
  showLogout?: boolean;
}

const {
  title,
  description = 'OTTV Trainingslager Tianjin 2026 — Tagebuch und Camp-Infos.',
  mode = 'public',
  showLogout = mode === 'intern',
} = Astro.props;

const pageTitle = title === 'OTTV Tianjin 2026' ? title : `${title} · OTTV Tianjin 2026`;
const path = stripBase(Astro.url.pathname);
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#5b3d9a" />
    <link rel="icon" type="image/png" href={href('/images/ottv-logo.png')} />
    <link rel="apple-touch-icon" href={href('/images/ottv-logo.png')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&family=Bricolage+Grotesque:opsz,wght@12..96,500..800&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body data-mode={mode}>
    <a class="skip-link" href="#main-content">Zum Inhalt springen</a>
    <header class="site-header">
      <div class="wrap site-header__inner">
        <a class="brand" href={href('/')}>
          <img
            class="brand__logo"
            src={href('/images/ottv-logo.png')}
            alt="OTTV — Ostschweizer Tischtennisverband"
            width="800"
            height="375"
          />
          <span class="brand__text">
            <span class="brand__name">Tianjin 2026</span>
            <span class="brand__sub">Trainingslager · China</span>
          </span>
        </a>

        <details class="nav-drawer">
          <summary class="nav-drawer__toggle" aria-label="Menü öffnen">
            <span class="nav-drawer__bars" aria-hidden="true"></span>
          </summary>
          <nav class="nav" aria-label="Hauptnavigation">
            <a href={href('/')} aria-current={path === '/' ? 'page' : undefined}>Start</a>
            <a href={href('/blog')} aria-current={path.startsWith('/blog') ? 'page' : undefined}>Tagebuch</a>
            <a href={href('/lager')} aria-current={path.startsWith('/lager') ? 'page' : undefined}>Lager</a>
            <a
              class:list={['nav-camp', mode === 'intern' && 'is-active']}
              href={href('/intern')}
              aria-current={path.startsWith('/intern') ? 'page' : undefined}
            >
              Lagerteilnehmer
            </a>
          </nav>
        </details>

        <nav class="nav nav--desktop" aria-label="Hauptnavigation">
          <a href={href('/')} aria-current={path === '/' ? 'page' : undefined}>Start</a>
          <a href={href('/blog')} aria-current={path.startsWith('/blog') ? 'page' : undefined}>Tagebuch</a>
          <a href={href('/lager')} aria-current={path.startsWith('/lager') ? 'page' : undefined}>Lager</a>
          <a
            class:list={['nav-camp', mode === 'intern' && 'is-active']}
            href={href('/intern')}
            aria-current={path.startsWith('/intern') ? 'page' : undefined}
          >
            Lagerteilnehmer
          </a>
        </nav>
      </div>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="wrap site-footer__inner">
        <p>OTTV Tianjin 2026 · Training mit Ma Wenge</p>
        <p>
          {
            showLogout ? (
              <button class="btn btn-ghost" type="button" data-camp-logout style="min-height:2.75rem;padding:0.45rem 1rem;font-size:0.95rem">
                Abmelden
              </button>
            ) : (
              <a href={href('/intern')}>Camp-Bereich</a>
            )
          }
        </p>
      </div>
    </footer>
    <CampAuth />
    <script>
      const drawer = document.querySelector('.nav-drawer');
      const toggle = document.querySelector('.nav-drawer__toggle');

      function syncMenuLabel() {
        if (!(drawer instanceof HTMLDetailsElement) || !(toggle instanceof HTMLElement)) return;
        toggle.setAttribute('aria-label', drawer.open ? 'Menü schliessen' : 'Menü öffnen');
        toggle.setAttribute('aria-expanded', drawer.open ? 'true' : 'false');
      }

      if (drawer instanceof HTMLDetailsElement) {
        syncMenuLabel();
        drawer.addEventListener('toggle', syncMenuLabel);
      }

      document.querySelectorAll('.nav-drawer .nav a').forEach((link) => {
        link.addEventListener('click', () => {
          if (drawer instanceof HTMLDetailsElement) drawer.open = false;
        });
      });
    </script>
  </body>
</html>
